<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="kirin_purchase_form_wizard" model="ir.ui.view">
            <field name="name">批量确认订单</field>
            <field name="model">purchase.confirm.wizard</field>
            <field name="arch" type="xml">
                <form string="">
                    <h1>确定要确认这些订单吗?</h1>
                    <footer>
                        <button name="button_confirm" string="确认" class="oe_highlight" type="object" />
                        or
                        <button special="cancel" string="Cancel" class="oe_link" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_purchase_order" model="ir.actions.act_window">
            <field name="name">批量确认</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">purchase.confirm.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_purchase_order"/>
        </record>

        <record id="kirin_purchase_receive_form_wizard" model="ir.ui.view">
            <field name="name">批量接收</field>
            <field name="model">purchase.receive.wizard</field>
            <field name="arch" type="xml">
                <form string="">
                    <h1>确定要接收这些订单吗？</h1>
                    <footer>
                        <button name="button_confirm" string="确认" class="oe_highlight" type="object" />
                        or
                        <button special="cancel" string="Cancel" class="oe_link" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="kirin_purchase_receive" model="ir.actions.act_window">
            <field name="name">批量接收</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">purchase.receive.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_purchase_order"/>
        </record>

    </data>
</odoo>